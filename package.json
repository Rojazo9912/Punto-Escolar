{
  "name": "punto-escolar",
  "version": "1.0.0",
  "description": "Sistema de Punto de Venta para Papelerías Mexicanas",
  "main": "desktop/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\" \"npm run start:electron\"",
    "start:electron": "wait-on http://localhost:5173 && electron .",
    "install:all": "npm install && npm install --prefix backend && npm install --prefix frontend",
    "build:frontend": "npm run build --prefix frontend",
    "build:electron": "npm run build:frontend && electron-builder",
    "build:fast": "npm run build:frontend && electron-builder --win --dir"
  },
  "keywords": [
    "pos",
    "punto-de-venta",
    "electron",
    "react",
    "express",
    "mysql"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^26.8.1",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "pdfkit": "^0.15.0"
  },
  "build": {
    "appId": "com.puntoescolar.app",
    "productName": "Punto Escolar",
    "publish": [
      {
        "provider": "github",
        "owner": "Rojazo9912",
        "repo": "Punto-Escolar"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "asarUnpack": [
      "node_modules/@prisma/client/**/*",
      "node_modules/.prisma/**/*",
      "**/*.node"
    ],
    "files": [
      "desktop/**/*",
      "backend/**/*",
      "frontend/dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "desktop/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
